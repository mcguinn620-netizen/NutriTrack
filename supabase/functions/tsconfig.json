{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowImportingTsExtensions": true,
    "types": ["https://deno.land/x/types/index.d.ts"]
  },
  "include": ["**/*.ts"],
  "exclude": ["../../node_modules"]
}
